# ============================================
# ATS Resume Builder — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# ── Groq AI ─────────────────────────────────────
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── MongoDB ─────────────────────────────────────
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ats_resume_builder

# ── CORS ────────────────────────────────────────
# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Authentication ──────────────────────────────
# Random secret for JWT signing (use `openssl rand -hex 32` to generate)
JWT_SECRET=change_me_to_a_random_secret

# ── Admin account (seeded on first startup) ─────
ADMIN_EMAIL=admin@atsbuilder.com
ADMIN_PASSWORD=Admin@123

# ── Environment ─────────────────────────────────
# Set to "production" on deployed servers
FASTAPI_ENV=development
